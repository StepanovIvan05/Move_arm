<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.move_arm.comtroller.HoverSettingsController"
           stylesheets="@../css/dark-glow.css">

    <HBox alignment="CENTER" spacing="36">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <VBox alignment="CENTER" spacing="20" prefWidth="320" styleClass="dark-panel">
            <Label text="Настройки наведения" styleClass="title-label"/>

            <!-- Радиус -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="Размер цели" styleClass="subtitle-label"/>
                <Slider fx:id="radiusSlider" min="20" max="100"
                        majorTickUnit="10" minorTickCount="0"
                        snapToTicks="true" showTickLabels="true"/>
                <Label fx:id="radiusValueLabel"/>
            </VBox>

            <!-- Анимация -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="Анимация" styleClass="subtitle-label"/>
                <ComboBox fx:id="animationTypeComboBox" prefWidth="220"/>
                <Button text="▶ Просмотреть" onAction="#handlePlayAnimation"/>
            </VBox>

            <!-- Тип генератора -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="Тип генератора" styleClass="subtitle-label"/>
                <ComboBox fx:id="generatorTypeComboBox" prefWidth="220"/>
            </VBox>

            <!-- 🔥 ДИНАМИЧЕСКИЙ КОНТЕЙНЕР -->
            <StackPane fx:id="generatorOptionsContainer" alignment="CENTER">
                <!-- RANDOM: только сид -->
                <VBox fx:id="seedContainer" alignment="CENTER" spacing="8">
                    <Label text="Сид генерации" styleClass="subtitle-label"/>
                    <ComboBox fx:id="seedComboBox" prefWidth="220"/>
                </VBox>

                <!-- ADAPTIVE: только сложность -->
                <VBox fx:id="adaptiveContainer" alignment="CENTER" spacing="8"
                      visible="false" managed="false">
                    <Label text="Сложность траектории" styleClass="subtitle-label"/>
                    <ComboBox fx:id="difficultyComboBox" prefWidth="220"/>
                </VBox>
            </StackPane>

            <Button text="Сохранить и выйти" onAction="#handleSaveAndExit"/>
        </VBox>

        <Pane fx:id="previewRoot" prefWidth="420" prefHeight="420" styleClass="preview-box">
            <Circle fx:id="previewCircle" fill="#ff5555" stroke="white" strokeWidth="2"/>
        </Pane>
    </HBox>
</StackPane>