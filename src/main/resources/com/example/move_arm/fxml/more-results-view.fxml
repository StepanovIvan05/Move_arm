<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.move_arm.comtroller.MoreResultsController"
            stylesheets="@../css/dark-glow.css">

    <VBox spacing="20"
          alignment="TOP_CENTER"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <Label text="Средние значения" styleClass="subtitle-label"/>
        <Label fx:id="modeLabel" text="" styleClass="info-label"/>

        <GridPane fx:id="summaryTable"
                  hgap="30"
                  vgap="10"
                  styleClass="dark-panel">
            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>
        </GridPane>

        <Separator/>

        <Label text="Графики" styleClass="subtitle-label"/>

        <ScrollPane fitToWidth="true"
                    fitToHeight="false"
                    VBox.vgrow="ALWAYS"
                    styleClass="dark-scroll-pane">

            <VBox spacing="30"
                  alignment="CENTER"
                  fillWidth="true">

                <padding>
                    <Insets top="20"
                            right="30"
                            bottom="20"
                            left="40"/>
                </padding>

                <LineChart fx:id="clickIntervalsChart"
                           minHeight="450"
                           prefHeight="450"
                           maxWidth="Infinity"
                           title="Интервал между кликами">
                    <xAxis>
                        <NumberAxis label="Номер клика"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Интервал (мс)" side="LEFT"/>
                    </yAxis>
                </LineChart>

                <LineChart fx:id="cursorDistanceChart"
                           minHeight="450"
                           prefHeight="450"
                           maxWidth="Infinity"
                           title="Расстояние от центра">
                    <xAxis>
                        <NumberAxis label="Номер клика"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Расстояние (px)" side="LEFT"/>
                    </yAxis>
                </LineChart>

                <LineChart fx:id="movementSpeedChart"
                           minHeight="450"
                           prefHeight="450"
                           maxWidth="Infinity"
                           title="Скорость движения">
                    <xAxis>
                        <NumberAxis label="Номер клика"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Скорость (px/мс)" side="LEFT"/>
                    </yAxis>
                </LineChart>

                <LineChart fx:id="normalizedDeviationChart"
                           minHeight="450"
                           prefHeight="450"
                           maxWidth="Infinity"
                           title="Нормализованное отклонение">
                    <xAxis>
                        <NumberAxis label="Номер клика"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Отклонение" side="LEFT"/>
                    </yAxis>
                </LineChart>

            </VBox>
        </ScrollPane>

        <Button text="В меню"
                onAction="#handleToMenuButton"/>

    </VBox>

</AnchorPane>